doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Notification from #{appName}
    style.
      body {
        font-family: Arial, sans-serif;
        background-color: #f4f4f4;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 30px auto;
        background-color: #ffffff;
        padding: 30px;
        border-radius: 8px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }
      h1 {
        color: #333333;
        font-size: 24px;
        margin-bottom: 20px;
      }
      p {
        color: #555555;
        font-size: 16px;
        line-height: 1.5;
      }
      .button {
        display: inline-block;
        padding: 12px 25px;
        margin-top: 20px;
        font-size: 16px;
        color: #ffffff;
        background-color: #ff6f00;
        text-decoration: none;
        border-radius: 5px;
      }
      .footer {
        margin-top: 30px;
        font-size: 12px;
        color: #999999;
        text-align: center;
      }

  body
    .container
      h1 Hello #{userName} 👋
      p Welcome to #{appName}! We’re excited to have you onboard. Here’s a quick overview of your account and what’s next.
      p Feel free to explore and start using our features today.
      //- Optional button if needed
      if actionLink
        a.button(href=actionLink) Get Started
      .footer
        p &copy; #{year} #{appName}. All rights reserved.