doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Order Confirmation
    style.
      /* Reset */
      body, table, td, th { margin:0; padding:0; font-family: Arial, sans-serif; }
      body { background-color: #f8f8f8; padding: 20px; }
      .container { background-color: #fff; padding: 20px; border-radius: 8px; max-width: 600px; margin: auto; }
      h1 { color: #333; font-size: 24px; }
      p { color: #555; font-size: 16px; line-height: 1.5; }
      table { width: 100%; border-collapse: collapse; margin-top: 20px; }
      th, td { border: 1px solid #ddd; padding: 8px; text-align: left; font-size: 14px; }
      th { background-color: #f2f2f2; }
      .total { font-weight: bold; }
      .track-btn { display: inline-block; padding: 10px 20px; margin-top: 10px; background-color: #007bff; color: #fff; text-decoration: none; border-radius: 5px; }
      .track-btn:hover { background-color: #0056b3; }
      .footer { margin-top: 20px; font-size: 0.9em; color: #555; }

      /* Responsive */
      @media only screen and (max-width: 600px) {
        .container { padding: 15px; }
        h1 { font-size: 20px; }
        table, th, td { font-size: 12px; }
        .track-btn { padding: 8px 16px; font-size: 14px; }
      }

  body
    .container
      h1 Hello #{firstName},
      p Thank you for your order! Here are your order details:

      if orderNumber
        p Order Number: #{orderNumber}
      if orderDate
        p Order Date: #{orderDate}

      table
        thead
          tr
            th Product
            th Color
            th Size
            th Quantity
            th Price
        tbody
          each item in items
            tr
              td #{item.title}
              td #{item.color}
              td #{item.size}
              td #{item.quantity}
              td #{item.price}
        tfoot
          tr
            td(colspan="4").total Total
            td #{totalPrice}

      p Payment Method: #{paymentMethod}
      p Shipping Address: #{shippingAddress}

      if urlOrCode
        p
          | Track your order here:
          br
          a.track-btn(href=urlOrCode) Track Order

      .footer
        p Thank you for shopping with us!