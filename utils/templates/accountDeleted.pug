doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Account Deleted
    style.
      body { font-family: Arial, sans-serif; background-color: #f4f4f4; margin:0; padding:0; }
      .container { max-width:600px; margin:30px auto; background:#fff; padding:30px; border-radius:8px; box-shadow:0 4px 10px rgba(0,0,0,0.1); }
      h1 { color:#333; font-size:24px; }
      p { color:#555; font-size:16px; line-height:1.5; }
      .footer { margin-top:30px; font-size:12px; color:#999; text-align:center; }
  body
    .container
      h1 Account Deleted
      p Hello #{userName},
      p Your account on #{appName} has been successfully deleted. We’re sorry to see you go!
      .footer
        p &copy; #{year} #{appName}. All rights reserved.