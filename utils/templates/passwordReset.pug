extends base

block content
  p Hello #{firstName},

  p You requested to reset your password.

  p Click the button below:

  table(role="presentation" border="0" cellpadding="0" cellspacing="0")
    tr
      td
        a(
          href=`${urlOrCode}`
          target="_blank"
          style="background-color:#28a745; color:#fff; padding:12px 20px; text-decoration:none; border-radius:5px; display:inline-block;"
        ) Reset Password

  p This link will expire in 10 minutes.

  p If button doesn't work, use this link:

  p
    a(href=`${urlOrCode}` target="_blank") #{url}