doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Email Verification
    style.
      body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 20px; }
      .container { background: #fff; padding: 30px; max-width: 600px; margin: auto; border-radius: 8px; }
      .code { font-size: 24px; font-weight: bold; color: #007BFF; margin: 20px 0; }
  body
    .container
      h2 Hello #{firstName},
      p You requested to verify your email.
      p Your verification code is:
      p.code #{urlOrCode}
      p This code will expire in 10 minutes.
      hr
      p If you did not request this, please ignore this email.